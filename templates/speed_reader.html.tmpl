{{define "title"}}Speed Reader{{end}}
{{define "description"}}Speed Text Reader - Read text faster one word at a time{{end}}
{{define "content"}}
<aside>
  <div class="header-label">Tool · 02</div>
  <div class="name">
    <h1>Speed Reader</h1>
    <p>Rapid Serial Visual Presentation</p>
  </div>

  <div class="section">
    <h2>Instructions</h2>
    <div class="items">
      <span>1. Paste your text</span>
      <span>2. Set your speed (WPM)</span>
      <span>3. Click Start</span>
    </div>
  </div>

  <div class="section">
    <h2>Controls</h2>
    <div class="items">
      <span><kbd>Space</kbd> Pause/Resume</span>
      <span><kbd>&larr;</kbd> Previous word</span>
      <span><kbd>&rarr;</kbd> Next word</span>
      <span><kbd>&uarr;</kbd> Speed up</span>
      <span><kbd>&darr;</kbd> Slow down</span>
    </div>
  </div>

  <div class="section">
    <h2>Navigation</h2>
    <div class="items">
      <a href="/">Back to Home</a>
    </div>
  </div>

  <div class="section-code">No. 990-22-2.0</div>
</aside>

<main data-controller="speed-reader" data-action="keydown@document->speed-reader#keydown">
  <div class="page-header">
    <div class="page-title">
      <h1>Speed<br>Reader</h1>
      <div class="subtitle">RSVP Text Processing</div>
    </div>
    <div class="page-code">
      <div>Module</div>
      <div>02</div>
    </div>
  </div>

  <div class="speed-reader">
    <div class="input-section">
      <label for="text-input">Input Text</label>
      <textarea id="text-input" data-speed-reader-target="textInput" data-action="input->speed-reader#textChanged" placeholder="Paste the text you want to read here..."></textarea>
      <span data-speed-reader-target="timeEstimate"></span>
    </div>

    <div class="controls">
      <div class="speed-control">
        <label for="wpm-slider">Speed</label>
        <input id="wpm-slider" data-speed-reader-target="wpmSlider" data-action="input->speed-reader#updateWpm" type="range" min="100" max="800" value="300" step="5">
        <span class="wpm-value"><span data-speed-reader-target="wpmDisplay">300</span> WPM</span>
      </div>
      <button class="btn" data-speed-reader-target="startBtn" data-action="click->speed-reader#start">Start</button>
      <button class="btn" data-speed-reader-target="resetBtn" data-action="click->speed-reader#reset">Reset</button>
      <span class="status" data-speed-reader-target="status">Ready</span>
    </div>

    <div class="display-section">
      <div class="word-display" data-speed-reader-target="wordDisplay">
        <span class="before"></span>
        <span class="focus"></span>
        <span class="after"></span>
      </div>
      <div class="progress-info">
        <span data-speed-reader-target="progress">0 / 0 words</span>
      </div>
    </div>
  </div>
</main>
{{end}}
